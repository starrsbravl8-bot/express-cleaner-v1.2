<UserControl x:Class="ExpressCleaner.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="Dashboard" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
        
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Статистика -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                <Border Background="#2196F3" Padding="20" Margin="0,0,10,0" CornerRadius="5" Width="200">
                    <StackPanel>
                        <TextBlock Text="Всего файлов" Foreground="White" FontSize="14"/>
                        <TextBlock x:Name="TotalFilesText" Text="0" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                
                <Border Background="#4CAF50" Padding="20" Margin="0,0,10,0" CornerRadius="5" Width="200">
                    <StackPanel>
                        <TextBlock Text="Можно освободить" Foreground="White" FontSize="14"/>
                        <TextBlock x:Name="SpaceToFreeText" Text="0 MB" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                
                <Border Background="#FF9800" Padding="20" CornerRadius="5" Width="200">
                    <StackPanel>
                        <TextBlock Text="Категорий" Foreground="White" FontSize="14"/>
                        <TextBlock x:Name="CategoriesText" Text="0" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </StackPanel>
            
            <!-- Быстрые действия -->
            <StackPanel Grid.Row="1" Margin="0,0,0,20">
                <TextBlock Text="Быстрые действия" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Быстрый анализ" Click="QuickAnalysis_Click" Padding="15,10" Margin="0,0,10,0" Background="#2196F3" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="Очистить временные файлы" Click="CleanTemp_Click" Padding="15,10" Margin="0,0,10,0" Background="#4CAF50" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="Информация о системе" Click="SystemInfo_Click" Padding="15,10" Background="#FF9800" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </StackPanel>
            
            <!-- Информация -->
            <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="1" Padding="15" CornerRadius="5">
                <ScrollViewer>
                    <TextBlock x:Name="InfoText" TextWrapping="Wrap" Text="Добро пожаловать в Express Cleaner!&#x0a;&#x0a;Используйте меню слева для навигации по разделам программы."/>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>

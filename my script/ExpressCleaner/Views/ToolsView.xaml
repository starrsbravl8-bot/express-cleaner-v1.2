<UserControl x:Class="ExpressCleaner.Views.ToolsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="Инструменты" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
        
        <StackPanel Grid.Row="1">
            <Border Background="#F5F5F5" Padding="15" Margin="0,0,0,10" CornerRadius="5">
                <StackPanel>
                    <TextBlock Text="Очистка DNS кэша" FontSize="16" FontWeight="Bold"/>
                    <TextBlock Text="Очистить кэш DNS для устранения проблем с сетью" Margin="0,5,0,10" TextWrapping="Wrap"/>
                    <Button Content="Очистить DNS" Click="ClearDNS_Click" Padding="15,8" Background="#2196F3" Foreground="White" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>
            
            <Border Background="#F5F5F5" Padding="15" Margin="0,0,0,10" CornerRadius="5">
                <StackPanel>
                    <TextBlock Text="Очистка диска Windows" FontSize="16" FontWeight="Bold"/>
                    <TextBlock Text="Запустить встроенную утилиту очистки диска Windows" Margin="0,5,0,10" TextWrapping="Wrap"/>
                    <Button Content="Запустить очистку диска" Click="DiskCleanup_Click" Padding="15,8" Background="#4CAF50" Foreground="White" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>
            
            <Border Background="#F5F5F5" Padding="15" CornerRadius="5">
                <StackPanel>
                    <TextBlock Text="Информация о системе" FontSize="16" FontWeight="Bold"/>
                    <TextBlock Text="Просмотр подробной информации о системе" Margin="0,5,0,10" TextWrapping="Wrap"/>
                    <Button Content="Открыть информацию о системе" Click="SystemInfo_Click" Padding="15,8" Background="#FF9800" Foreground="White" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>

<UserControl x:Class="ExpressCleaner.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="Настройки" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
        
        <StackPanel Grid.Row="1">
            <TextBlock Text="Express Cleaner v1.0" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
            <TextBlock Text="Профессиональная утилита для очистки Windows" Margin="0,0,0,20" TextWrapping="Wrap"/>
            
            <TextBlock Text="Возможности:" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
            <TextBlock Text="• Очистка временных файлов системы" Margin="0,0,0,5"/>
            <TextBlock Text="• Очистка кэша браузеров" Margin="0,0,0,5"/>
            <TextBlock Text="• Анализ дискового пространства" Margin="0,0,0,5"/>
            <TextBlock Text="• Системные инструменты" Margin="0,0,0,5"/>
            <TextBlock Text="• Безопасная очистка с предупреждениями" Margin="0,0,0,20"/>
            
            <TextBlock Text="© 2024 Express Cleaner. Все права защищены." Margin="0,20,0,0" Foreground="Gray"/>
        </StackPanel>
    </Grid>
</UserControl>

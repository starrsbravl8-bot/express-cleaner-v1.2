<UserControl x:Class="ExpressCleaner.Views.SystemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="Информация о системе" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
        
        <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Padding="15">
            <ScrollViewer>
                <TextBlock x:Name="SystemInfoText" TextWrapping="Wrap" FontFamily="Consolas" FontSize="14"/>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
